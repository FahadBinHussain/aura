<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Aura.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <ScrollViewer Padding="32,24,32,32" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="24" MaxWidth="700" HorizontalAlignment="Left">

            <!-- Header -->
            <TextBlock Text="Settings"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

            <!-- General Section -->
            <StackPanel Spacing="8">
                <TextBlock Text="General"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,4"/>

                <!-- Start with Windows card -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="Start with Windows"
                                       FontSize="14"
                                       FontWeight="Medium"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Text="Automatically launch Aura when you sign in to Windows."
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <ToggleSwitch x:Name="StartWithWindowsToggle"
                                      Grid.Column="1"
                                      OnContent=""
                                      OffContent=""
                                      Margin="16,0,0,0"
                                      VerticalAlignment="Center"
                                      Toggled="StartWithWindowsToggle_Toggled"/>
                    </Grid>
                </Border>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
