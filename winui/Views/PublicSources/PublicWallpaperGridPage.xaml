<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Aura.Views.PublicSources.PublicWallpaperGridPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Aura.Models"
    Background="Transparent">

    <Grid Padding="28,24,28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="6">
                <TextBlock x:Name="TitleTextBlock"
                           Text="Wallpapers"
                           FontSize="32"
                           FontWeight="SemiBold"/>
                <TextBlock x:Name="DescriptionTextBlock"
                           Text="Browse wallpapers from this source."
                           TextWrapping="Wrap"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           FontSize="14"/>
            </StackPanel>

            <Button Grid.Column="1"
                    Content="Refresh"
                    Padding="16,8"
                    VerticalAlignment="Center"
                    Click="RefreshButton_Click"/>
        </Grid>

        <StackPanel Grid.Row="1" Margin="0,0,0,16" Spacing="10">
            <InfoBar x:Name="StatusInfoBar"
                     IsOpen="False"
                     IsClosable="True"/>
            <StackPanel x:Name="ModeButtonsPanel"
                        Orientation="Horizontal"
                        Spacing="8"/>
        </StackPanel>

        <GridView x:Name="WallpapersGridView"
                  Grid.Row="2"
                  ItemsSource="{x:Bind Wallpapers}"
                  IsItemClickEnabled="True"
                  SelectionMode="None"
                  ItemClick="WallpapersGridView_ItemClick"
                  ContainerContentChanging="WallpapersGridView_ContainerContentChanging"
                  Loaded="WallpapersGridView_Loaded"
                  Padding="0,0,0,20">
            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid x:Name="WallpapersWrapGrid"
                                   Orientation="Horizontal"
                                   SizeChanged="WallpapersWrapGrid_SizeChanged"/>
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="models:WallpaperItem">
                    <Grid Width="300" Height="190" Margin="6">
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="12"/>
                        <Image x:Name="WallpaperImage"
                               Source="{x:Bind ImageSource, Mode=OneWay}"
                               Stretch="UniformToFill"/>
                        <Border VerticalAlignment="Bottom"
                                MinHeight="58"
                                Background="#99000000"
                                CornerRadius="0,0,12,12"
                                Padding="12,8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="{x:Bind Title}"
                                           Foreground="White"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"/>
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10" Margin="0,4,0,0">
                                    <TextBlock Text="{x:Bind Resolution}"
                                               Foreground="#E6FFFFFF"
                                               FontSize="11"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{x:Bind QualityTag}"
                                               Foreground="#E6FFFFFF"
                                               FontSize="11"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>

        <ProgressBar x:Name="LoadingProgressBar"
                     Grid.Row="3"
                     IsIndeterminate="True"
                     Visibility="Collapsed"
                     Margin="0,8,0,0"/>
    </Grid>
</Page>
