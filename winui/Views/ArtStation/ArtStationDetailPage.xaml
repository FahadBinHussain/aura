<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Aura.Views.ArtStation.ArtStationDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24" Spacing="14">
                <TextBlock x:Name="TitleTextBlock"
                           Text="ArtStation artwork"
                           Style="{StaticResource TitleTextBlockStyle}"
                           TextWrapping="Wrap"/>

                <TextBlock x:Name="DescriptionTextBlock"
                           Opacity="0.78"
                           TextWrapping="WrapWholeWords"
                           MaxLines="4"/>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="0.5"
                        CornerRadius="12"
                        HorizontalAlignment="Center">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Image x:Name="ArtworkImage"
                               Grid.Row="0"
                               Source="ms-appx:///Assets/placeholder-wallpaper-1000.png"
                               Stretch="Uniform"
                               CacheMode="BitmapCache"
                               MaxWidth="1200"
                               MaxHeight="820"/>

                        <Grid Grid.Row="1"
                              Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                              BorderThickness="0,0.5,0,0"
                              Padding="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0"
                                        Orientation="Horizontal"
                                        Spacing="16"
                                        VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xEB51;" FontSize="14"/>
                                    <TextBlock x:Name="LikesTextBlock" Text="0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE890;" FontSize="14"/>
                                    <TextBlock x:Name="ViewsTextBlock" Text="0"/>
                                </StackPanel>
                                <TextBlock x:Name="ResolutionTextBlock"
                                           Text="ArtStation"
                                           Opacity="0.72"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Spacing="12">
                                <Button x:Name="SetAsWallpaperButton"
                                        Background="Transparent"
                                        BorderBrush="Transparent">
                                    <Button.Flyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem Text="Set as Desktop Wallpaper"
                                                            Click="SetAsDesktopWallpaperItem_Click">
                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xE2B1;" />
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                            <MenuFlyoutItem Text="Set as Lock Screen"
                                                            Click="SetAsLockScreenItem_Click">
                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xE72E;" />
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                        </MenuFlyout>
                                    </Button.Flyout>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE136;" FontSize="14"/>
                                        <TextBlock Text="Set" FontSize="14" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Button>

                                <Button Background="Transparent"
                                        BorderBrush="Transparent"
                                        Click="DownloadButton_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE74E;" FontSize="14"/>
                                        <TextBlock Text="Download" FontSize="14" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Button>

                                <Button Background="Transparent"
                                        BorderBrush="Transparent"
                                        Click="ViewOnWebButton_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE774;" FontSize="14"/>
                                        <TextBlock Text="View on Web" FontSize="14" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <InfoBar x:Name="StatusInfoBar"
                         IsOpen="False"
                         Severity="Informational"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
